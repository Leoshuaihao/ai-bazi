# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# JWT 密钥（必须设置随机强密钥，无默认值）
JWT_SECRET=your-random-256-bit-secret-here

# CORS 白名单（逗号分隔多个域名）
ALLOWED_ORIGINS=https://ai-bazi-production.up.railway.app,https://ai-bazi.railway.app

# 支付配置（可选，未配置时走Mock模式）
XORPAY_APP_ID=
XORPAY_API_SECRET=
